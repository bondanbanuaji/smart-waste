# ─── Database ────────────────────────────────────
DATABASE_URL="mysql://root:@localhost:3306/smart_trash_db"

# ─── NextAuth ────────────────────────────────────
NEXTAUTH_SECRET="super-secret-key-change-in-production-smarttrash2026"
NEXTAUTH_URL="http://localhost:3000"

# ─── IoT Local Network ───────────────────────────
NEXT_PUBLIC_SERVER_LOCAL_IP="192.168.1.10"
NEXT_PUBLIC_SERVER_PORT="3000"

# ─── Threshold Notifikasi ────────────────────────
CAPACITY_ALERT_THRESHOLD=90

# ─── Sensor Threshold ────────────────────────────
MOISTURE_THRESHOLD=500
